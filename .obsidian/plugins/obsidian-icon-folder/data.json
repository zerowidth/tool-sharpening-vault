{
  "settings": {
    "migrated": 6,
    "iconPacksPath": ".obsidian/icons",
    "fontSize": 16,
    "emojiStyle": "native",
    "iconColor": null,
    "recentlyUsedIcons": [
      "LiLayers2",
      "LiGanttChartSquare",
      "LiLayoutPanelLeft",
      "LiBookMarked",
      "LiBookCopy"
    ],
    "recentlyUsedIconsSize": 5,
    "rules": [
      {
        "rule": ".*",
        "icon": "LiFile",
        "for": "everything",
        "order": 0
      },
      {
        "rule": ".*/",
        "icon": "LiFolder",
        "for": "everything",
        "order": 2
      },
      {
        "rule": "Issue.*",
        "icon": "LiBug",
        "for": "everything",
        "order": 3
      },
      {
        "rule": "Project.*(",
        "icon": "LiClipboardList",
        "for": "everything",
        "order": 3
      }
    ],
    "extraMargin": {
      "top": 0,
      "right": 4,
      "bottom": 0,
      "left": 0
