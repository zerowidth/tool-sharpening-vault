{
  "settings": {
    "migrated": 6,
    "iconPacksPath": ".obsidian/icons",
    "fontSize": 16,
    "emojiStyle": "native",
    "iconColor": null,
    "recentlyUsedIcons": [
      "LiCalendarRange",
      "LiLayers2",
      "LiGanttChartSquare",
      "LiLayoutPanelLeft",
      "LiBookMarked"
    ],
    "recentlyUsedIconsSize": 5,
    "rules": [
      {
        "rule": ".",
        "icon": "LiFile",
        "for": "files",
        "order": 0
      },
      {
        "rule": ".",
        "icon": "LiFolderClosed",
        "for": "folders",
        "order": 2
      },
      {
        "rule": ".md$",
        "icon": "LiFileText",
        "for": "files",
        "order": 2
      },
      {
        "rule": "0 - Daily/\\d{4}",
        "icon": "LiCalendarDays",
        "for": "folders",
        "order": 3,
        "useFilePath": true
      },
      {
        "rule": "Issue.*",
        "icon": "LiBug",
        "for": "files",
        "order": 5
      },
      {
        "rule": "Project.*(",
        "icon": "LiClipboardList",
        "for": "files",
        "order": 5
      }
    ],
    "extraMargin": {
      "top": 0,
      "right": 4,
      "bottom": 0,
      "left": 0
    },
    "iconInTabsEnabled": false,
    "iconInTitleEnabled": false,
    "iconInTitlePosition": "above",
    "iconInFrontmatterEnabled": false,
    "iconInFrontmatterFieldName": "icon",
    "iconColorInFrontmatterFieldName": "iconColor",
    "iconsBackgroundCheckEnabled": false,
    "iconsInNotesEnabled": true,
    "iconsInLinksEnabled": true,
    "iconIdentifier": ":",
    "lucideIconPackType": "native",
    "debugMode": false,
    "useInternalPlugins": false
  },
  "0 - Daily": "LiCalendarRange",
  "Attachments": "LiPaperclip",
  "4 - Archive": "LiArchive",
  "2 - Areas": "LiLayoutPanelLeft",
  "1 - Projects": "LiGanttChartSquare",
  "Templates": "LiLayers2"
}